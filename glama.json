{
  "$schema": "https://glama.ai/mcp/schemas/server.json",
  "maintainers": ["bowenerchen"],
  "name": "cipherhub-mcp",
  "description": "Production-grade cryptography toolkit - 31 MCP tools covering AES, RSA, ECC, SM2/SM3/SM4/SM9, ZUC, ML-KEM, ML-DSA, and hybrid KEX. Certified with AWS KMS (64/64) and Tencent Cloud KMS (39/39).",
  "type": "mcp_server",
  "status": "stable",
  "version": "1.9.4",
  "tools": 31,
  "prompts": 6,
  "resources": 5,
  "transport": ["http"],
  "remote": {
    "url": "https://tools.cipherhub.cloud/cipherhub/mcp",
    "type": "streamable-http"
  },
  "keywords": [
    "cryptography",
    "aes",
    "rsa",
    "ecc",
    "sm2",
    "sm3",
    "sm4",
    "sm9",
    "zuc",
    "ml-kem",
    "ml-dsa",
    "post-quantum",
    "hmac",
    "hash",
    "encryption",
    "signature",
    "key-exchange",
    "chinese-crypto",
    "国密",
    "kms",
    "hsm",
    "security"
  ],
  "categories": [
    "security",
    "cryptography",
    "developer-tools"
  ],
  "features": {
    "hash": {
      "algorithms": ["SHA-1", "SHA-224", "SHA-256", "SHA-384", "SHA-512", "SM3"]
    },
    "symmetric": {
      "algorithms": ["AES-128", "AES-256", "SM4"],
      "modes": ["CBC", "GCM", "ChaCha20-Poly1305"]
    },
    "asymmetric": {
      "algorithms": ["RSA-2048", "RSA-3072", "RSA-4096", "ECC-SECP256R1", "ECC-SECP384R1", "ECC-SECP521R1", "X25519", "Ed25519"]
    },
    "chinese-standards": {
      "algorithms": ["SM2", "SM3", "SM4", "ZUC-128"]
    },
    "post-quantum": {
      "algorithms": ["ML-KEM-512", "ML-KEM-768", "ML-KEM-1024", "ML-DSA-44", "ML-DSA-65", "ML-DSA-87"],
      "hybrid": ["X25519+ML-KEM-768"]
    },
    "interoperability": {
      "aws-kms": "64/64 passed",
      "tencent-kms": "39/39 passed"
    }
  },
  "repository": {
    "url": "https://github.com/bowenerchen/CipherHUB-MCP-Server",
    "type": "git"
  },
  "homepage": "https://tools.cipherhub.cloud",
  "author": {
